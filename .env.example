# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Anthropic Claude (AI yorumları için)
ANTHROPIC_API_KEY=sk-ant-...

# TCMB API (opsiyonel, scraping fallback var)
TCMB_API_KEY=your_tcmb_key

# Railway/Production otomatik set eder
PORT=8000

# Veritabanı yolu (opsiyonel, default: kizilelma.db)
# KIZILELMA_DB=/data/kizilelma.db

# Çalışma ortamı
ENVIRONMENT=development
